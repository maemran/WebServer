http {

# ============================================
# DEFAULT ERROR PAGES
# ============================================

    error_page 404 /errors/404.html;
    error_page 403 /errors/403.html;
    error_page 500 502 503 504 /errors/50x.html;

# ============================================
# SERVER 1 (Website A)
# Listening Interface + Port
# ============================================

    server {

        # Interface : Port
        listen 127.0.0.1:8080;

        server_name localhost;

        # Maximum allowed client body size
        client_max_body_size 10M;

        root /var/www/site1;

        index index.html index.htm;

# --------------------------------------------
# ROUTE "/"
# --------------------------------------------

        location / {

            # Allowed HTTP Methods
            limit_except GET POST {
                deny all;
            }

            # Directory listing ON
            autoindex on;

            # Default file if directory
            index index.html;
        }

# --------------------------------------------
# ROUTE "/images"
# Custom root
# --------------------------------------------

        location /images {

            root /tmp/www;

            autoindex off;

            limit_except GET {
                deny all;
            }
        }

# --------------------------------------------
# REDIRECTION
# --------------------------------------------

        location /old-page {

            return 301 /new-page;
        }

# --------------------------------------------
# FILE UPLOAD
# --------------------------------------------

        location /upload {

            limit_except POST {
                deny all;
            }

            client_max_body_size 50M;

            root /var/uploads;

            autoindex off;
        }

# --------------------------------------------
# ERROR PAGE LOCATION
# --------------------------------------------

        location /errors {
            root /var/www;
            internal;
        }
    }


# ============================================
# SERVER 2 (Another Website)
# Multiple Interface / Port Example
# ============================================

    server {

        listen 0.0.0.0:9090;

        server_name example.com;

        root /var/www/site2;

        client_max_body_size 5M;

        index home.html;

        location / {

            autoindex off;

            limit_except GET HEAD {
                deny all;
            }
        }

        location /downloads {

            autoindex on;

            root /srv/files;

            index index.html;
        }
    }

}